@page "/timezones"
@attribute [ToolPage("Timezones", "🕓", "Compare time zones", 11)]
@using DevToolkit.Infrastructure
@using Microsoft.FluentUI.AspNetCore.Components
@using System
@using System.Globalization

<PageTitle>Timezone &amp; Schedule Helper</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px;">
    <FluentLabel Typo="Typography.PageTitle">Timezone &amp; Schedule Helper</FluentLabel>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
            <FluentLabel Typo="Typography.Subject">Reference Moment</FluentLabel>
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px; flex-wrap: wrap;">
                <div class="timezone-field">
                    <label>Local date &amp; time</label>
                    <input type="datetime-local" class="timezone-datetime-input" value="@ReferenceInputValue" @onchange="OnReferenceInputChanged" />
                </div>
                <div class="timezone-field">
                    <label>Source timezone</label>
                    <FluentCombobox Items="@_timezones"
                                    @bind-SelectedOption="ReferenceZone"
                                    Style="min-width: 260px;"
                                    Class="readonly-combo">
                        <OptionTemplate>@(context?.Label ?? string.Empty)</OptionTemplate>
                    </FluentCombobox>
                </div>
            </FluentStack>
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; flex-wrap: wrap;">
                <FluentButton Appearance="Appearance.Accent" OnClick="SetReferenceNow">Now</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="() => ShiftReferenceHours(1)">+1 hour</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="() => ShiftReferenceHours(24)">+1 day</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="() => ShiftReferenceHours(-1)">-1 hour</FluentButton>
            </FluentStack>
            <FluentLabel Style="opacity: 0.8;">@ReferenceSummary</FluentLabel>
        </FluentStack>
    </FluentCard>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
            <FluentLabel Typo="Typography.Subject">Tracked Timezones</FluentLabel>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 12px; flex-wrap: wrap; align-items: flex-end;">
                <div class="timezone-field">
                    <label>Add timezone</label>
                    <FluentCombobox Items="@_timezones"
                                    @bind-SelectedOption="_zoneToAdd"
                                    Style="min-width: 260px;"
                                    Class="readonly-combo">
                        <OptionTemplate>@(context?.Label ?? string.Empty)</OptionTemplate>
                    </FluentCombobox>
                </div>
                <FluentButton Appearance="Appearance.Accent" OnClick="AddTrackedZone">Add to list</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="ClearTrackedZones">Reset to defaults</FluentButton>
            </FluentStack>

            @if (!string.IsNullOrWhiteSpace(_timezoneMessage))
            {
                <FluentMessageBar Intent="@_timezoneMessageIntent">@_timezoneMessage</FluentMessageBar>
            }

            @if (_timeSnapshots.Count == 0)
            {
                <FluentLabel Style="opacity: 0.8;">Add at least one timezone to see conversions.</FluentLabel>
            }
            else
            {
                <div class="timezone-table">
                    @foreach (var snapshot in _timeSnapshots)
                    {
                        <div class="timezone-row">
                            <div class="timezone-row-main">
                                <strong>@snapshot.DisplayName</strong>
                                <span>@snapshot.DayNote</span>
                            </div>
                            <div class="timezone-row-time">
                                <span class="timezone-time">@snapshot.LocalText</span>
                                <span class="timezone-offset">@snapshot.OffsetText</span>
                            </div>
                            <div class="timezone-row-delta">@snapshot.DeltaText</div>
                            <div>
                                @if (!snapshot.IsReference)
                                {
                                    <FluentButton Appearance="Appearance.Stealth" Style="padding: 2px;" OnClick="() => RemoveTrackedZone(snapshot.ZoneId)">
                                        <FluentIcon Icon="Icons.Regular.Size20.Dismiss" />
                                    </FluentButton>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </FluentStack>
    </FluentCard>

