@page "/text-diff"
@attribute [ToolPage("Text Diff", "🧾", "Spot differences between snippets, configs, or payloads.", 14)]
@using DevToolkit.Infrastructure
@using DiffPlex
@using DiffPlex.Chunkers
@using DiffPlex.DiffBuilder
@using DiffPlex.DiffBuilder.Model
@using System.Linq

<PageTitle>Text Diff</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px;">
    <FluentLabel Typo="Typography.PageTitle">Text / Config Diff</FluentLabel>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 20px; flex-wrap: wrap;">
                <FluentStack Orientation="Orientation.Vertical" Style="flex: 1 1 300px; gap: 8px;">
                    <FluentLabel Typo="Typography.Subject">Left Text</FluentLabel>
                    <FluentTextArea Value="@_leftText"
                                    ValueChanged="@((string value) => _leftText = value)"
                                    Rows="14"
                                    Style="width: 100%; font-family: monospace;" />
                </FluentStack>

                <FluentStack Orientation="Orientation.Vertical" Style="flex: 1 1 300px; gap: 8px;">
                    <FluentLabel Typo="Typography.Subject">Right Text</FluentLabel>
                    <FluentTextArea Value="@_rightText"
                                    ValueChanged="@((string value) => _rightText = value)"
                                    Rows="14"
                                    Style="width: 100%; font-family: monospace;" />
                </FluentStack>
            </FluentStack>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 20px; flex-wrap: wrap; align-items: center;">
                <FluentCheckbox Checked="_ignoreWhitespace"
                                CheckedChanged="(bool? value) => _ignoreWhitespace = value ?? false"
                                Label="Ignore whitespace" />
                <FluentCheckbox Checked="_ignoreCase"
                                CheckedChanged="(bool? value) => _ignoreCase = value ?? false"
                                Label="Ignore case" />
            </FluentStack>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; flex-wrap: wrap;">
                <FluentButton Appearance="Appearance.Accent" OnClick="CompareText">Run Diff</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="SwapSides">Swap Inputs</FluentButton>
                <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearAll">Clear</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <FluentMessageBar Intent="@_statusIntent">@_statusMessage</FluentMessageBar>
    }

    @if (_diffResult is not null)
    {
        <FluentCard Style="padding: 20px;">
            <FluentLabel Typo="Typography.Subject">Summary</FluentLabel>
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 20px; flex-wrap: wrap; margin-top: 8px;">
                <FluentLabel><strong>Added:</strong> @_summary.Added</FluentLabel>
                <FluentLabel><strong>Removed:</strong> @_summary.Removed</FluentLabel>
                <FluentLabel><strong>Modified:</strong> @_summary.Modified</FluentLabel>
                <FluentLabel><strong>Total changes:</strong> @_summary.TotalChanges</FluentLabel>
            </FluentStack>
        </FluentCard>

        <FluentCard Style="padding: 20px;">
            <FluentLabel Typo="Typography.Subject">Diff Output</FluentLabel>
            <div class="diff-output" aria-label="diff results">
                @foreach (var line in _diffResult.Lines)
                {
                    var cssClass = $"diff-line {CssModifier(line.Type)}";
                    <div class="@cssClass">
                        <span class="diff-line-marker">@MarkerFor(line.Type)</span>
                        <pre>@(line.Text ?? string.Empty)</pre>
                    </div>
                }
            </div>
        </FluentCard>
    }
</FluentStack>
</div>

@code {
    private readonly InlineDiffBuilder _diffBuilder = new(new Differ());
    private readonly IChunker _chunker = new LineChunker();

    private string _leftText = @"GET /api/users HTTP/1.1
Host: api.example.com
Accept: application/json
X-Env: staging";

    private string _rightText = @"GET /api/users HTTP/1.1
Host: api.example.com
Accept: application/problem+json
X-Env: production";

    private bool _ignoreWhitespace = true;
    private bool _ignoreCase = false;

    private DiffPaneModel? _diffResult;
    private DiffSummary _summary = DiffSummary.Empty;
    private string _statusMessage = string.Empty;
    private MessageIntent _statusIntent = MessageIntent.Info;

    private void CompareText()
    {
        _statusMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_leftText) && string.IsNullOrWhiteSpace(_rightText))
        {
            _diffResult = null;
            _summary = DiffSummary.Empty;
            _statusIntent = MessageIntent.Info;
            _statusMessage = "Enter or paste text in at least one panel.";
            return;
        }

        _diffResult = _diffBuilder.BuildDiffModel(
            _leftText ?? string.Empty,
            _rightText ?? string.Empty,
            _ignoreWhitespace,
            _ignoreCase,
            _chunker);

        _summary = DiffSummary.From(_diffResult);

        if (_summary.TotalChanges == 0)
        {
            _statusIntent = MessageIntent.Success;
            _statusMessage = "No differences detected.";
        }
        else
        {
            _statusIntent = MessageIntent.Info;
            _statusMessage = $"Found {_summary.TotalChanges} change(s).";
        }
    }

    private void SwapSides()
    {
        (_leftText, _rightText) = (_rightText, _leftText);
    }

    private void ClearAll()
    {
        _leftText = string.Empty;
        _rightText = string.Empty;
        _diffResult = null;
        _summary = DiffSummary.Empty;
        _statusMessage = string.Empty;
    }

    private static string MarkerFor(ChangeType type) => type switch
    {
        ChangeType.Inserted => "+",
        ChangeType.Deleted => "-",
        ChangeType.Modified => "~",
        _ => " "
    };

    private static string CssModifier(ChangeType type) => type switch
    {
        ChangeType.Inserted => "diff-line-inserted",
        ChangeType.Deleted => "diff-line-deleted",
        ChangeType.Modified => "diff-line-modified",
        _ => "diff-line-unchanged"
    };

    private sealed record DiffSummary(int Added, int Removed, int Modified)
    {
        public int TotalChanges => Added + Removed + Modified;

        public static DiffSummary Empty { get; } = new(0, 0, 0);

        public static DiffSummary From(DiffPaneModel model)
        {
            var added = model.Lines.Count(line => line.Type == ChangeType.Inserted);
            var removed = model.Lines.Count(line => line.Type == ChangeType.Deleted);
            var modified = model.Lines.Count(line => line.Type == ChangeType.Modified);
            return new DiffSummary(added, removed, modified);
        }
    }
}
