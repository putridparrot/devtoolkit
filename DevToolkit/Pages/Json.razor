@page "/json"
@attribute [ToolPage("JSON", "🧾", "Format, minify, and validate JSON payloads.", 4)]
@using System.Text.Json
@using DevToolkit.Infrastructure
@using DevToolkit.Services
@using System.Threading
@inject ISettingsService SettingsService
@implements IDisposable

<PageTitle>JSON</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; height: 100%;">
    <FluentLabel Typo="Typography.PageTitle">JSON Tools</FluentLabel>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 12px;">
            <FluentLabel Typo="Typography.Subject">Input JSON</FluentLabel>
            <FluentTextArea Value="@_jsonInput"
                            ValueChanged="OnJsonInputChanged"
                            Rows="12"
                            Style="width: 100%; font-family: monospace;" />

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; flex-wrap: wrap;">
                <FluentButton Appearance="Appearance.Accent" OnClick="FormatJson">Format</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="MinifyJson">Minify</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="ValidateJson">Validate</FluentButton>
                <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearAll">Clear</FluentButton>
            </FluentStack>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <FluentMessageBar Intent="@_statusIntent">@_statusMessage</FluentMessageBar>
            }
        </FluentStack>
    </FluentCard>

    <FluentCard Style="padding: 20px;">
        <FluentLabel Typo="Typography.Subject">Output</FluentLabel>
        <FluentTextArea Value="@_jsonOutput"
                        ValueChanged="OnJsonOutputChanged"
                        Rows="12"
                        Style="width: 100%; margin-top: 10px; font-family: monospace;" />
    </FluentCard>
</FluentStack>
</div>

@code {
    private string _jsonInput = string.Empty;
    private string _jsonOutput = string.Empty;
    private string _statusMessage = string.Empty;
    private MessageIntent _statusIntent = MessageIntent.Info;
    private AppSettings? _settings;
    private readonly TimeSpan _autosaveDelay = TimeSpan.FromMilliseconds(600);
    private CancellationTokenSource? _autosaveCts;
    private bool _settingsLoaded;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.LoadSettingsAsync();
        var stored = _settings.Json ??= new JsonToolsSettings();
        _jsonInput = stored.LastInput ?? string.Empty;
        _jsonOutput = stored.LastOutput ?? string.Empty;
        _settingsLoaded = true;
    }

    private async Task FormatJson()
    {
        if (ProcessJson(writeIndented: true, mode: "formatted"))
        {
            await PersistAsync();
        }
    }

    private async Task MinifyJson()
    {
        if (ProcessJson(writeIndented: false, mode: "minified"))
        {
            await PersistAsync();
        }
    }

    private Task ValidateJson()
    {
        _statusMessage = string.Empty;

        try
        {
            using var _ = JsonDocument.Parse(_jsonInput);
            _statusMessage = "Valid JSON.";
            _statusIntent = MessageIntent.Success;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Invalid JSON: {ex.Message}";
            _statusIntent = MessageIntent.Error;
        }

        return Task.CompletedTask;
    }

    private bool ProcessJson(bool writeIndented, string mode)
    {
        _statusMessage = string.Empty;

        try
        {
            using var doc = JsonDocument.Parse(_jsonInput);
            _jsonOutput = JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = writeIndented });
            _statusMessage = $"JSON {mode} successfully.";
            _statusIntent = MessageIntent.Success;
            return true;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Invalid JSON: {ex.Message}";
            _statusIntent = MessageIntent.Error;
            return false;
        }
    }

    private async Task ClearAll()
    {
        _jsonInput = string.Empty;
        _jsonOutput = string.Empty;
        _statusMessage = string.Empty;
        _statusIntent = MessageIntent.Info;
        await PersistAsync();
    }

    private void OnJsonInputChanged(string value)
    {
        _jsonInput = value;
        ScheduleAutoSave();
    }

    private void OnJsonOutputChanged(string value)
    {
        _jsonOutput = value;
        ScheduleAutoSave();
    }

    private void ScheduleAutoSave()
    {
        if (!_settingsLoaded)
        {
            return;
        }

        _autosaveCts?.Cancel();
        var cts = new CancellationTokenSource();
        _autosaveCts = cts;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(_autosaveDelay, cts.Token);
                await InvokeAsync(PersistAsync);
            }
            catch (TaskCanceledException)
            {
            }
        });
    }

    private async Task PersistAsync()
    {
        if (_settings is null)
        {
            return;
        }

        var jsonSettings = _settings.Json ??= new JsonToolsSettings();
        jsonSettings.LastInput = _jsonInput;
        jsonSettings.LastOutput = _jsonOutput;
        jsonSettings.LastUpdated = DateTimeOffset.UtcNow;

        await SettingsService.SaveSettingsAsync(_settings);
    }

    public void Dispose()
    {
        _autosaveCts?.Cancel();
    }
}
