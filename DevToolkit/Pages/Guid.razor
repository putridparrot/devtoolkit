@page "/guid"
@using DevToolkit.Infrastructure
@inject IJSRuntime JSRuntime
@attribute [ToolPage("GUID/UUID", "🧬", "Generate GUIDs in multiple formats including bulk generation.", 8)]

<PageTitle>GUID/UUID</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; height: 100%;">
    <FluentLabel Typo="Typography.PageTitle">GUID / UUID Tools</FluentLabel>

        <FluentCard Style="padding: 20px;">
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 12px;">
                <FluentLabel Typo="Typography.Subject">Generate Single GUID</FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; flex-wrap: wrap;">
                    <FluentButton Appearance="Appearance.Accent" OnClick="GenerateSingle">Generate</FluentButton>
                    <FluentButton Appearance="Appearance.Outline" OnClick="ClearSingle">Clear</FluentButton>
                </FluentStack>

                <FluentLabel Style="display: flex; align-items: center; gap: 6px;">
                    <span><strong>D</strong> (default): @_singleGuidD</span>
                    @if (HasGuidValue(_singleGuidD))
                    {
                        <FluentButton Appearance="Appearance.Stealth" Style="padding: 2px;" OnClick="() => CopyToClipboard(_singleGuidD)">
                            <FluentIcon Icon="Icons.Regular.Size20.Copy" />
                        </FluentButton>
                    }
                </FluentLabel>
                <FluentLabel Style="display: flex; align-items: center; gap: 6px;">
                    <span><strong>N</strong> (digits): @_singleGuidN</span>
                    @if (HasGuidValue(_singleGuidN))
                    {
                        <FluentButton Appearance="Appearance.Stealth" Style="padding: 2px;" OnClick="() => CopyToClipboard(_singleGuidN)">
                            <FluentIcon Icon="Icons.Regular.Size20.Copy" />
                        </FluentButton>
                    }
                </FluentLabel>
                <FluentLabel Style="display: flex; align-items: center; gap: 6px;">
                    <span><strong>B</strong> (braces): @_singleGuidB</span>
                    @if (HasGuidValue(_singleGuidB))
                    {
                        <FluentButton Appearance="Appearance.Stealth" Style="padding: 2px;" OnClick="() => CopyToClipboard(_singleGuidB)">
                            <FluentIcon Icon="Icons.Regular.Size20.Copy" />
                        </FluentButton>
                    }
                </FluentLabel>
                <FluentLabel Style="display: flex; align-items: center; gap: 6px;">
                    <span><strong>P</strong> (parentheses): @_singleGuidP</span>
                    @if (HasGuidValue(_singleGuidP))
                    {
                        <FluentButton Appearance="Appearance.Stealth" Style="padding: 2px;" OnClick="() => CopyToClipboard(_singleGuidP)">
                            <FluentIcon Icon="Icons.Regular.Size20.Copy" />
                        </FluentButton>
                    }
                </FluentLabel>
            </FluentStack>
        </FluentCard>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 12px;">
            <FluentLabel Typo="Typography.Subject">Bulk Generate</FluentLabel>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; align-items: center; overflow: visible;">
                <FluentLabel>Count</FluentLabel>
                <FluentNumberField Value="@_bulkCount" ValueChanged="@((int? v) => _bulkCount = v ?? 10)" Min="1" Max="500" Step="1" Style="width: 120px;" />
                <FluentLabel>Format</FluentLabel>
                <FluentCombobox Items="@_formats" @bind-SelectedOption="_selectedFormat" Style="width: 140px;" Class="readonly-combo">
                    <OptionTemplate>@context</OptionTemplate>
                </FluentCombobox>
            </FluentStack>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; flex-wrap: wrap;">
                <FluentButton Appearance="Appearance.Accent" OnClick="GenerateBulk">Generate List</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="ClearBulk">Clear</FluentButton>
            </FluentStack>

            <FluentTextArea Value="@_bulkOutput" ValueChanged="@((string v) => _bulkOutput = v)" Rows="12" Style="width: 100%; font-family: monospace;" Placeholder="Generated GUID list appears here..." />
        </FluentStack>
    </FluentCard>
</FluentStack>
</div>

@code {
    private string _singleGuidD = "-";
    private string _singleGuidN = "-";
    private string _singleGuidB = "-";
    private string _singleGuidP = "-";

    private int _bulkCount = 10;
    private readonly List<string> _formats = new() { "D", "N", "B", "P" };
    private string _selectedFormat = "D";
    private string _bulkOutput = string.Empty;

    private void GenerateSingle()
    {
        var guid = global::System.Guid.NewGuid();
        _singleGuidD = guid.ToString("D");
        _singleGuidN = guid.ToString("N");
        _singleGuidB = guid.ToString("B");
        _singleGuidP = guid.ToString("P");
    }

    private void ClearSingle()
    {
        _singleGuidD = "-";
        _singleGuidN = "-";
        _singleGuidB = "-";
        _singleGuidP = "-";
    }

    private void GenerateBulk()
    {
        var format = string.IsNullOrWhiteSpace(_selectedFormat) ? "D" : _selectedFormat;
        var lines = new List<string>(_bulkCount);

        for (var i = 0; i < _bulkCount; i++)
        {
            lines.Add(global::System.Guid.NewGuid().ToString(format));
        }

        _bulkOutput = string.Join(Environment.NewLine, lines);
    }

    private void ClearBulk()
    {
        _bulkOutput = string.Empty;
    }

    private async Task CopyToClipboard(string value)
    {
        if (!string.IsNullOrEmpty(value) && JSRuntime is not null)
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", value);
        }
    }

    private static bool HasGuidValue(string value)
    {
        return !string.IsNullOrWhiteSpace(value) && !string.Equals(value, "-", StringComparison.Ordinal);
    }

}

<style>
    .overlay-select .fluent-select__listbox,
    .readonly-combo .fluent-combobox__listbox {
        top: 100% !important;
        bottom: auto !important;
    }

    /* Visual cue that the combo behaves like a select */
    .readonly-combo::part(control) input {
        caret-color: transparent;
    }

</style>


<script>
(function () {
    const allowedKeys = new Set(['ArrowDown', 'ArrowUp', 'ArrowLeft', 'ArrowRight', 'Home', 'End', 'Tab', 'Enter', 'Escape']);

    const blockInput = (event) => {
        if (event.type === 'beforeinput') {
            event.preventDefault();
            return;
        }

        if (event.type === 'keydown') {
            if (event.key && (event.key.length === 1 || !allowedKeys.has(event.key))) {
                event.preventDefault();
            }
        }
    };

    const applyReadOnly = (combo) => {
        if (!combo || combo.__readonlyApplied) {
            return;
        }

        combo.__readonlyApplied = true;

        const ensureInputState = () => {
            const input = combo.shadowRoot?.querySelector('input');
            if (!input) {
                return;
            }

            if (!input.hasAttribute('readonly')) {
                input.setAttribute('readonly', 'readonly');
            }

            input.addEventListener('beforeinput', blockInput);
            input.addEventListener('keydown', blockInput);
        };

        ensureInputState();

        if (combo.shadowRoot) {
            const shadowObserver = new MutationObserver(ensureInputState);
            shadowObserver.observe(combo.shadowRoot, { childList: true, subtree: true });
        }
    };

    const initializeAll = () => {
        document.querySelectorAll('fluent-combobox.readonly-combo').forEach(applyReadOnly);
    };

    initializeAll();

    const domObserver = new MutationObserver(initializeAll);
    domObserver.observe(document.body, { childList: true, subtree: true });
})();
</script>
