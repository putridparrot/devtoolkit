@page "/snippets"
@attribute [ToolPage("Snippets", "📝", "Save and manage code snippets backed by GitHub Gists.", 1)]
@using System.Net.Http.Headers
@using System.Text.Json
@using System.Text.Json.Serialization
@using DevToolkit.Shared.Services
@inject ISettingsService SettingsService

<PageTitle>Snippets</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; height: 100%;">
    <FluentLabel Typo="Typography.PageTitle">Code Snippets Manager</FluentLabel>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
            <FluentLabel Typo="Typography.Subject">GitHub Gists</FluentLabel>

            @if (string.IsNullOrWhiteSpace(_gistUrl))
            {
                <FluentMessageBar Intent="MessageIntent.Warning">
                    Configure your Gist URL in Settings to load gists.
                </FluentMessageBar>
            }
            else
            {
                <FluentLabel>Configured URL: @_gistUrl</FluentLabel>
                <FluentButton Appearance="Appearance.Accent" OnClick="LoadGistsAsync" Disabled="@_isLoadingGists">
                    @(_isLoadingGists ? "Loading..." : "Load Gists")
                </FluentButton>

                @if (string.IsNullOrWhiteSpace(_gistToken))
                {
                    <FluentMessageBar Intent="MessageIntent.Warning">
                        Configure a GitHub token in Settings to create/update gists.
                    </FluentMessageBar>
                }

                @if (!string.IsNullOrWhiteSpace(_gistErrorMessage))
                {
                    <FluentMessageBar Intent="MessageIntent.Error">
                        @_gistErrorMessage
                    </FluentMessageBar>
                }

                @if (_gists.Any())
                {
                    <FluentDataGrid Items="@_gists.AsQueryable()" GridTemplateColumns="2fr 1fr 120px" Style="margin-top: 10px;">
                        <TemplateColumn Title="Description" Context="gist">
                            @(!string.IsNullOrWhiteSpace(gist.Description) ? gist.Description : "(No description)")
                        </TemplateColumn>
                        <TemplateColumn Title="Updated" Context="gist">
                            @gist.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        </TemplateColumn>
                        <TemplateColumn Title="Action" Context="gist">
                            <FluentButton Appearance="Appearance.Lightweight" OnClick="() => LoadGistIntoEditorAsync(gist.Id)">Load</FluentButton>
                        </TemplateColumn>
                    </FluentDataGrid>
                }
            }
        </FluentStack>
    </FluentCard>
    
    <FluentCard Style="padding: 20px;">
        <FluentLabel Typo="Typography.Subject">Create New Snippet</FluentLabel>
        @if (!string.IsNullOrWhiteSpace(_loadedGistId))
        {
            <FluentMessageBar Intent="MessageIntent.Info" Style="margin-top: 10px;">
                Editing loaded gist: @_loadedGistId
            </FluentMessageBar>
        }
        <FluentTextField Value="@_snippetTitle" ValueChanged="@((string val) => _snippetTitle = val)" Placeholder="Snippet Title" Style="width: 100%; margin-top: 10px;" />
        <FluentTextArea Value="@_snippetContent" ValueChanged="@((string val) => _snippetContent = val)" Placeholder="Paste your code snippet here..." Rows="10" Style="width: 100%; margin-top: 10px;" />
        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px; margin-top: 10px;">
            <FluentButton Appearance="Appearance.Outline" OnClick="CreateGist">Create Gist</FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="SaveGistAsync" Disabled="@_isSavingGist">
                @(_isSavingGist ? "Saving..." : "Save Gist")
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="AddSnippet">Save Snippet</FluentButton>
        </FluentStack>

        @if (!string.IsNullOrWhiteSpace(_gistSaveMessage))
        {
            <FluentMessageBar Intent="@_gistSaveMessageIntent" Style="margin-top: 10px;">
                @_gistSaveMessage
            </FluentMessageBar>
        }
    </FluentCard>

    <FluentLabel Typo="Typography.Subject">Saved Snippets</FluentLabel>
    
    @if (_snippets.Any())
    {
        @foreach (var snippet in _snippets)
        {
            <FluentCard Style="padding: 15px;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@snippet.Title</FluentLabel>
                    <FluentTextArea Value="@snippet.Content" ReadOnly="true" Rows="5" Style="width: 100%;" />
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="() => RemoveSnippet(snippet)">Delete</FluentButton>
                </FluentStack>
            </FluentCard>
        }
    }
    else
    {
        <FluentLabel>No snippets saved yet. Create your first snippet above!</FluentLabel>
    }
</FluentStack>
</div>

@code {
    private string _snippetTitle = string.Empty;
    private string _snippetContent = string.Empty;
    private readonly List<CodeSnippet> _snippets = new();
    private string _gistUrl = string.Empty;
    private string _gistToken = string.Empty;
    private string _gistErrorMessage = string.Empty;
    private bool _isLoadingGists;
    private List<GistSummary> _gists = new();
    private string _loadedGistId = string.Empty;
    private bool _isSavingGist;
    private string _gistSaveMessage = string.Empty;
    private MessageIntent _gistSaveMessageIntent = MessageIntent.Success;

    protected override async Task OnInitializedAsync()
    {
        var settings = await SettingsService.LoadSettingsAsync();
        _gistUrl = settings.Snippets.GistUrl;
        _gistToken = settings.Snippets.GistToken;

        if (!string.IsNullOrWhiteSpace(_gistUrl))
        {
            await LoadGistsAsync();
        }
    }

    private async Task LoadGistsAsync()
    {
        _gistErrorMessage = string.Empty;
        _gistSaveMessage = string.Empty;
        _gists.Clear();

        var userName = TryExtractGistUserName(_gistUrl);
        if (string.IsNullOrWhiteSpace(userName))
        {
            _gistErrorMessage = "Unable to determine GitHub username from configured Gist URL.";
            return;
        }

        _isLoadingGists = true;

        try
        {
            using var httpClient = CreateGithubClient();
            var response = await httpClient.GetAsync($"https://api.github.com/users/{userName}/gists");
            response.EnsureSuccessStatusCode();

            await using var stream = await response.Content.ReadAsStreamAsync();
            var data = await JsonSerializer.DeserializeAsync<List<GistListItem>>(stream) ?? [];

            _gists = data.Select(g => new GistSummary
            {
                Id = g.Id,
                Description = g.Description ?? string.Empty,
                UpdatedAt = g.UpdatedAt
            }).ToList();
        }
        catch (Exception ex)
        {
            _gistErrorMessage = $"Error loading gists: {ex.Message}";
        }
        finally
        {
            _isLoadingGists = false;
        }
    }

    private async Task LoadGistIntoEditorAsync(string gistId)
    {
        _gistErrorMessage = string.Empty;
        _gistSaveMessage = string.Empty;

        try
        {
            using var httpClient = CreateGithubClient();
            var response = await httpClient.GetAsync($"https://api.github.com/gists/{gistId}");
            response.EnsureSuccessStatusCode();

            await using var stream = await response.Content.ReadAsStreamAsync();
            var gist = await JsonSerializer.DeserializeAsync<GistDetail>(stream);

            if (gist is null || gist.Files.Count == 0)
            {
                _gistErrorMessage = "Selected gist has no files.";
                return;
            }

            var file = gist.Files.Values.FirstOrDefault(f => !string.IsNullOrWhiteSpace(f.Content)) ?? gist.Files.Values.First();
            var content = file.Content;

            if ((string.IsNullOrWhiteSpace(content) || file.Truncated) && !string.IsNullOrWhiteSpace(file.RawUrl))
            {
                content = await httpClient.GetStringAsync(file.RawUrl);
            }

            _snippetTitle = !string.IsNullOrWhiteSpace(file.FileName)
                ? file.FileName
                : (!string.IsNullOrWhiteSpace(gist.Description) ? gist.Description : gist.Id);

            _snippetContent = content ?? string.Empty;
            _loadedGistId = gist.Id;
        }
        catch (Exception ex)
        {
            _gistErrorMessage = $"Error loading gist content: {ex.Message}";
        }
    }

    private static HttpClient CreateGithubClient()
    {
        var client = new HttpClient();
        client.DefaultRequestHeaders.UserAgent.Add(new ProductInfoHeaderValue("DevToolkit", "1.0"));
        client.DefaultRequestHeaders.Accept.Add(new MediaTypeWithQualityHeaderValue("application/vnd.github+json"));
        return client;
    }

    private static HttpClient CreateGithubClient(string token)
    {
        var client = CreateGithubClient();
        client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return client;
    }

    private async Task SaveGistAsync()
    {
        _gistSaveMessage = string.Empty;
        _gistErrorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_snippetTitle) || string.IsNullOrWhiteSpace(_snippetContent))
        {
            _gistSaveMessage = "Snippet title and content are required to save a gist.";
            _gistSaveMessageIntent = MessageIntent.Warning;
            return;
        }

        if (string.IsNullOrWhiteSpace(_gistToken))
        {
            _gistSaveMessage = "GitHub token is required. Configure it in Settings.";
            _gistSaveMessageIntent = MessageIntent.Warning;
            return;
        }

        _isSavingGist = true;

        try
        {
            using var httpClient = CreateGithubClient(_gistToken);

            var fileName = BuildFileName(_snippetTitle);
            var filesPayload = new Dictionary<string, object?>
            {
                [fileName] = new { content = _snippetContent }
            };

            var payload = new
            {
                description = _snippetTitle,
                @public = false,
                files = filesPayload
            };

            HttpResponseMessage response;
            if (string.IsNullOrWhiteSpace(_loadedGistId))
            {
                response = await httpClient.PostAsJsonAsync("https://api.github.com/gists", payload);
            }
            else
            {
                response = await httpClient.PatchAsJsonAsync($"https://api.github.com/gists/{_loadedGistId}", payload);
            }

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                throw new InvalidOperationException($"GitHub API error ({(int)response.StatusCode}): {body}");
            }

            var savedGist = await response.Content.ReadFromJsonAsync<GistDetail>();
            if (savedGist is not null)
                _loadedGistId = savedGist.Id;

            _gistSaveMessage = string.IsNullOrWhiteSpace(_loadedGistId)
                ? "Gist created."
                : $"Gist saved ({_loadedGistId}).";
            _gistSaveMessageIntent = MessageIntent.Success;

            await LoadGistsAsync();
        }
        catch (Exception ex)
        {
            _gistSaveMessage = $"Error saving gist: {ex.Message}";
            _gistSaveMessageIntent = MessageIntent.Error;
        }
        finally
        {
            _isSavingGist = false;
        }
    }

    private static string BuildFileName(string title)
    {
        var cleaned = title.Trim();
        if (string.IsNullOrWhiteSpace(cleaned))
            return "snippet.txt";

        foreach (var c in Path.GetInvalidFileNameChars())
            cleaned = cleaned.Replace(c, '_');

        return cleaned.Contains('.') ? cleaned : $"{cleaned}.txt";
    }

    private static string TryExtractGistUserName(string url)
    {
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri))
            return string.Empty;

        var segments = uri.AbsolutePath.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (uri.Host.Contains("api.github.com", StringComparison.OrdinalIgnoreCase) &&
            segments.Length >= 2 &&
            segments[0].Equals("users", StringComparison.OrdinalIgnoreCase))
        {
            return segments[1];
        }

        if (uri.Host.Contains("gist.github.com", StringComparison.OrdinalIgnoreCase) && segments.Length >= 1)
        {
            return segments[0];
        }

        return string.Empty;
    }

    private void AddSnippet()
    {
        if (!string.IsNullOrWhiteSpace(_snippetTitle) && !string.IsNullOrWhiteSpace(_snippetContent))
        {
            _snippets.Add(new CodeSnippet
            {
                Id = global::System.Guid.NewGuid(),
                Title = _snippetTitle,
                Content = _snippetContent
            });

            _snippetTitle = string.Empty;
            _snippetContent = string.Empty;
        }
    }

    private void CreateGist()
    {
        _loadedGistId = string.Empty;
        _snippetTitle = string.Empty;
        _snippetContent = string.Empty;
        _gistSaveMessage = string.Empty;
    }

    private void RemoveSnippet(CodeSnippet snippet)
    {
        _snippets.Remove(snippet);
    }

    private class CodeSnippet
    {
        public global::System.Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
    }

    private class GistSummary
    {
        public string Id { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTimeOffset UpdatedAt { get; set; }
    }

    private class GistListItem
    {
        [JsonPropertyName("id")]
        public string Id { get; set; } = string.Empty;

        [JsonPropertyName("description")]
        public string? Description { get; set; }

        [JsonPropertyName("updated_at")]
        public DateTimeOffset UpdatedAt { get; set; }
    }

    private class GistDetail
    {
        [JsonPropertyName("id")]
        public string Id { get; set; } = string.Empty;

        [JsonPropertyName("description")]
        public string? Description { get; set; }

        [JsonPropertyName("files")]
        public Dictionary<string, GistFile> Files { get; set; } = [];
    }

    private class GistFile
    {
        [JsonPropertyName("filename")]
        public string? FileName { get; set; }

        [JsonPropertyName("raw_url")]
        public string? RawUrl { get; set; }

        [JsonPropertyName("content")]
        public string? Content { get; set; }

        [JsonPropertyName("truncated")]
        public bool Truncated { get; set; }
    }
}
