@page "/base64-url"
@attribute [ToolPage("Base64/URL", "🔤", "Encode and decode Base64 and URL strings.", 5)]
@using System.Text

<PageTitle>Base64/URL</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; height: 100%;">
    <FluentLabel Typo="Typography.PageTitle">Base64 / URL Tools</FluentLabel>

    <FluentCard Style="padding: 20px;">
        <FluentTabs>
            <FluentTab Label="Base64">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 15px; padding: 20px;">
                    <FluentLabel Typo="Typography.Subject">Input</FluentLabel>
                    <FluentTextArea Value="@_base64Input"
                                    ValueChanged="@((string value) => _base64Input = value)"
                                    Rows="8"
                                    Style="width: 100%; font-family: monospace;" />

                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px;">
                        <FluentButton Appearance="Appearance.Accent" OnClick="EncodeBase64">Encode</FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="DecodeBase64">Decode</FluentButton>
                        <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearBase64">Clear</FluentButton>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(_base64Error))
                    {
                        <FluentMessageBar Intent="MessageIntent.Error">@_base64Error</FluentMessageBar>
                    }

                    <FluentLabel Typo="Typography.Subject">Output</FluentLabel>
                    <FluentTextArea Value="@_base64Output"
                                    ValueChanged="@((string value) => _base64Output = value)"
                                    Rows="8"
                                    Style="width: 100%; font-family: monospace;" />
                </FluentStack>
            </FluentTab>

            <FluentTab Label="URL">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 15px; padding: 20px;">
                    <FluentLabel Typo="Typography.Subject">Input</FluentLabel>
                    <FluentTextArea Value="@_urlInput"
                                    ValueChanged="@((string value) => _urlInput = value)"
                                    Rows="8"
                                    Style="width: 100%; font-family: monospace;" />

                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px;">
                        <FluentButton Appearance="Appearance.Accent" OnClick="EncodeUrl">Encode</FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="DecodeUrl">Decode</FluentButton>
                        <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearUrl">Clear</FluentButton>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(_urlError))
                    {
                        <FluentMessageBar Intent="MessageIntent.Error">@_urlError</FluentMessageBar>
                    }

                    <FluentLabel Typo="Typography.Subject">Output</FluentLabel>
                    <FluentTextArea Value="@_urlOutput"
                                    ValueChanged="@((string value) => _urlOutput = value)"
                                    Rows="8"
                                    Style="width: 100%; font-family: monospace;" />
                </FluentStack>
            </FluentTab>
        </FluentTabs>
    </FluentCard>
</FluentStack>
</div>

@code {
    private string _base64Input = string.Empty;
    private string _base64Output = string.Empty;
    private string _base64Error = string.Empty;

    private string _urlInput = string.Empty;
    private string _urlOutput = string.Empty;
    private string _urlError = string.Empty;

    private void EncodeBase64()
    {
        _base64Error = string.Empty;
        try
        {
            var bytes = Encoding.UTF8.GetBytes(_base64Input);
            _base64Output = Convert.ToBase64String(bytes);
        }
        catch (Exception ex)
        {
            _base64Error = $"Error encoding Base64: {ex.Message}";
        }
    }

    private void DecodeBase64()
    {
        _base64Error = string.Empty;
        try
        {
            var bytes = Convert.FromBase64String(_base64Input.Trim());
            _base64Output = Encoding.UTF8.GetString(bytes);
        }
        catch (Exception ex)
        {
            _base64Error = $"Error decoding Base64: {ex.Message}";
        }
    }

    private void EncodeUrl()
    {
        _urlError = string.Empty;
        try
        {
            _urlOutput = Uri.EscapeDataString(_urlInput);
        }
        catch (Exception ex)
        {
            _urlError = $"Error encoding URL: {ex.Message}";
        }
    }

    private void DecodeUrl()
    {
        _urlError = string.Empty;
        try
        {
            _urlOutput = Uri.UnescapeDataString(_urlInput);
        }
        catch (Exception ex)
        {
            _urlError = $"Error decoding URL: {ex.Message}";
        }
    }

    private void ClearBase64()
    {
        _base64Input = string.Empty;
        _base64Output = string.Empty;
        _base64Error = string.Empty;
    }

    private void ClearUrl()
    {
        _urlInput = string.Empty;
        _urlOutput = string.Empty;
        _urlError = string.Empty;
    }
}
