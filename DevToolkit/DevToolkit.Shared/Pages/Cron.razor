@page "/cron"
@attribute [ToolPage("Cron", "⏱️", "Validate cron expressions and preview upcoming run times.", 7)]
@using NCrontab

<PageTitle>Cron</PageTitle>

<div class="page-container">
<FluentStack Orientation="Orientation.Vertical" Style="gap: 20px; height: 100%;">
    <FluentLabel Typo="Typography.PageTitle">Cron Expression Helper</FluentLabel>

    <FluentCard Style="padding: 20px;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
            <FluentLabel Typo="Typography.Subject">Cron Expression</FluentLabel>
            <FluentTextField Value="@_cronExpression"
                             ValueChanged="@((string value) => _cronExpression = value)"
                             Placeholder="e.g. */5 * * * *"
                             Style="width: 100%;" />

            <FluentLabel Style="font-size: 0.875rem; opacity: 0.8;">Format: minute hour day month day-of-week</FluentLabel>

            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 10px;">
                <FluentButton Appearance="Appearance.Accent" OnClick="EvaluateCron">Evaluate</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="SetEveryFiveMinutes">Every 5 minutes</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="SetEveryHour">Every hour</FluentButton>
                <FluentButton Appearance="Appearance.Outline" OnClick="SetDailyMidnight">Daily at midnight</FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <FluentMessageBar Intent="MessageIntent.Error">@_errorMessage</FluentMessageBar>
    }

    @if (_nextRuns.Any())
    {
        <FluentCard Style="padding: 20px;">
            <FluentLabel Typo="Typography.Subject">Next Runs (Local Time)</FluentLabel>
            <FluentDataGrid Items="@_nextRuns.AsQueryable()" GridTemplateColumns="80px 2fr 2fr" Style="margin-top: 10px;">
                <PropertyColumn Property="@(r => r.Index)" Title="#" />
                <PropertyColumn Property="@(r => r.LocalTime)" Title="Local" />
                <PropertyColumn Property="@(r => r.UtcTime)" Title="UTC" />
            </FluentDataGrid>
        </FluentCard>
    }
</FluentStack>
</div>

@code {
    private string _cronExpression = "*/5 * * * *";
    private string _errorMessage = string.Empty;
    private readonly List<CronRun> _nextRuns = new();

    protected override void OnInitialized()
    {
        EvaluateCron();
    }

    private void EvaluateCron()
    {
        _errorMessage = string.Empty;
        _nextRuns.Clear();

        try
        {
            var schedule = CrontabSchedule.Parse(_cronExpression);
            var nowUtc = DateTime.UtcNow;
            var occurrences = schedule.GetNextOccurrences(nowUtc, nowUtc.AddYears(1)).Take(10).ToList();

            for (var i = 0; i < occurrences.Count; i++)
            {
                var utc = DateTime.SpecifyKind(occurrences[i], DateTimeKind.Utc);
                var local = utc.ToLocalTime();

                _nextRuns.Add(new CronRun
                {
                    Index = i + 1,
                    LocalTime = local.ToString("yyyy-MM-dd HH:mm:ss zzz"),
                    UtcTime = utc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                });
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Invalid cron expression: {ex.Message}";
        }
    }

    private void SetEveryFiveMinutes()
    {
        _cronExpression = "*/5 * * * *";
        EvaluateCron();
    }

    private void SetEveryHour()
    {
        _cronExpression = "0 * * * *";
        EvaluateCron();
    }

    private void SetDailyMidnight()
    {
        _cronExpression = "0 0 * * *";
        EvaluateCron();
    }

    private class CronRun
    {
        public int Index { get; set; }
        public string LocalTime { get; set; } = string.Empty;
        public string UtcTime { get; set; } = string.Empty;
    }
}
