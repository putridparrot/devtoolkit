@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject ISettingsService SettingsService
@inject IThemeService ThemeService
@using DevToolkit.Infrastructure
@using DevToolkit.Services
@implements IDisposable

<FluentDesignTheme @bind-Mode="@_currentMode" StorageName="theme"/>
<FluentLayout Style="height: 100vh; display: flex; flex-direction: column;">
    <FluentHeader Style="flex-shrink: 0">
        <FluentButton Appearance="Appearance.Stealth" OnClick="ToggleNav" BackgroundColor="transparent">
            <FluentIcon Icon="Icons.Regular.Size24.Navigation" Color="Color.Custom" Class="fluent-icon" />
        </FluentButton>


        <div class="title-bar">
            <FluentLabel Typo="Typography.Header">@CurrentTitle</FluentLabel>
            <FluentButton Appearance="Appearance.Stealth"
                          BackgroundColor="transparent"
                          OnClick="NavigateToSettings"
                          Title="Settings"
                          Class="settings-button icon-only" >
                <FluentIcon Icon="Icons.Regular.Size20.Settings" Color="Color.Custom" Class="fluent-icon" />
            </FluentButton>
        </div>
    </FluentHeader>
    <FluentStack Orientation="Orientation.Horizontal" Style="flex: 1; overflow: hidden;" Class="main-content">
        @if (_isNavOpen)
        {
            <FluentNavMenu Class="nav-menu open"
                           Width="250"
                           Title="Tools"
                           Style="flex-shrink: 0; height: 100%; overflow-y: auto;">
                <FluentNavLink Href="/" Match="NavLinkMatch.All" IconColor="Color.Accent">Home</FluentNavLink>
                @foreach (var tool in ToolRegistry.Tools)
                {
                    <FluentNavLink Href="@tool.Route" IconColor="Color.Accent">@tool.Name</FluentNavLink>
                }
            </FluentNavMenu>
        }

        <div class="content-area" @key="_currentMode">
            @Body
        </div>
    </FluentStack>
</FluentLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    .nav-menu.closed {
        display: none;
    }
</style>

@code {
    private string CurrentTitle { get; set; } = "Dev Toolkit";
    private DesignThemeModes _currentMode = DesignThemeModes.System;
    private bool _isNavOpen = true;

    private void ToggleNav()
    {
        _isNavOpen = !_isNavOpen;
    }

    protected override async Task OnInitializedAsync()
    {
        UpdateTitle();
        NavigationManager.LocationChanged += OnLocationChanged;
        ThemeService.ThemeChanged += OnThemeChanged;
        await LoadTheme();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateTitle();
    }

    private void OnThemeChanged(string theme)
    {
        ApplyTheme(theme);
    }

    private void UpdateTitle()
    {
        var path = "/" + NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimStart('/');
        var tool = ToolRegistry.Tools.FirstOrDefault(t => path.StartsWith(t.Route, StringComparison.OrdinalIgnoreCase));

        CurrentTitle = path switch
        {
            "/" => "Dev Toolkit",
            "/settings" => "Dev Toolkit - Settings",
            _ when tool is not null => $"Dev Toolkit - {tool.Name}",
            _ => "Dev Toolkit"
        };
        StateHasChanged();
    }

    private async Task LoadTheme()
    {
        var settings = await SettingsService.LoadSettingsAsync();
        ApplyTheme(settings.General.Theme);
    }

    public void ApplyTheme(string theme)
    {
        _currentMode = theme.ToLower() switch
        {
            "light" => DesignThemeModes.Light,
            "dark" => DesignThemeModes.Dark,
            _ => DesignThemeModes.System
        };
        StateHasChanged();
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo("/settings");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        if (ThemeService != null)
        {
            ThemeService.ThemeChanged -= OnThemeChanged;
        }
    }
}
